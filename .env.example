# ---------------------------------------------------------------------------
# grant-finder 環境変数サンプル
# .env.local にコピーして設定してください(.env* は git 管理外)
# ---------------------------------------------------------------------------

# Supabase (プロジェクトの Settings > API から取得)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# サービスロール鍵(サーバー専用・絶対に公開しない)。jobs/ と管理機能で使用
SUPABASE_SERVICE_ROLE_KEY=""

# jGrants 公開API(認証不要。出典表示が必要: Jグランツポータル https://www.jgrants-portal.go.jp )
JGRANTS_API_BASE_URL="https://api.jgrants-portal.go.jp/exp/v1/public"
# 取込時の既定キーワード(2文字以上必須)。カンマ区切りで複数指定可
JGRANTS_INGEST_KEYWORDS="補助金,助成金,事業,設備,IT,省力化,販路,事業承継"

# LLM関連性ランカー(Claude Haiku 4.5)。未設定なら決定論マッチングのみで動作
ANTHROPIC_API_KEY=""

# メール通知(Resend)。専用サブドメインから送る。未設定時は送信せずログのみ(dry-run)
RESEND_API_KEY=""
NOTIFY_FROM_EMAIL="補助金ファインダー <notify@notify.ikedakeikaku.jp>"

# バッチ(cron)実行を保護する共有シークレット(Route Handler の Bearer 検証に使用)
CRON_SECRET=""

# 通知メール内リンク生成に使うアプリのベースURL
APP_BASE_URL="http://localhost:3000"
